{
  "manifest_version": 3,
  "name": "Auto Media Downloader",
  "version": "1.0",
  "description": "Automatically downloads all images and videos when extension is clicked",
  "permissions": ["activeTab", "downloads", "scripting", "contextMenus"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/icons/icon48.png",
      "48": "/icons/icon48.png",
      "128": "/icons/icon128.png"
    }
  },
  "icons": {
    "16": "/icons/icon48.png",
    "48": "/icons/icon48.png",
    "128": "/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}